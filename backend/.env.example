# Local development (copy to .env)
DATABASE_URL=postgresql+asyncpg://dailys:dailys@localhost:5432/dailys
ENVIRONMENT=dev
JWT_SECRET=change-me-in-production-use-long-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AI_VERIFICATION_ENABLED=false
AI_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
CORS_ORIGINS=*
INTERNAL_API_KEY=
LOG_LEVEL=INFO
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:8000
STORAGE_BACKEND=local
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
SENTRY_DSN=
TEST_DATABASE_URL=postgresql+asyncpg://dailys:dailys@localhost:5432/dailys_test

# Staging/production overrides (replace values above — do not duplicate ENVIRONMENT keys):
# ENVIRONMENT=staging
# JWT_SECRET=replace-with-long-random-secret-min-32-chars
# INTERNAL_API_KEY=replace-with-long-random-internal-key
# CORS_ORIGINS=http://localhost:8081,https://your-app.example.com
# PUBLIC_BASE_URL=https://api.your-app.example.com
# STORAGE_BACKEND=s3
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_PUBLIC_BASE_URL=https://your-cdn.example.com
# SENTRY_DSN=https://...@sentry.io/...
